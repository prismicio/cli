{
	"name": "prismic",
	"version": "0.0.0",
	"description": "Prismic's official command line tool",
	"workspaces": [
		"packages/plugin-kit",
		"packages/manager",
		"packages/adapter-next",
		"packages/adapter-nuxt",
		"packages/adapter-sveltekit"
	],
	"keywords": [
		"prismic",
		"typescript"
	],
	"license": "Apache-2.0",
	"author": "Prismic <contact@prismic.io> (https://prismic.io)",
	"repository": {
		"type": "git",
		"url": "ssh://git@github.com/prismicio/cli.git"
	},
	"bin": {
		"prismic": "./dist/index.mjs"
	},
	"files": [
		"./dist",
		"./src"
	],
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build:packages": "npm run --workspace=@prismicio/plugin-kit build && npm run --workspace=@prismicio/manager build && npm run --workspace=@prismicio/adapter-next build && npm run --workspace=@prismicio/adapter-nuxt build && npm run --workspace=@prismicio/adapter-sveltekit build",
		"build": "npm run build:packages && tsdown",
		"dev": "tsdown --watch",
		"format": "oxfmt",
		"prepare": "npm run build",
		"lint": "oxlint --deny-warnings --ignore-pattern packages/",
		"types": "tsc --noEmit",
		"unit": "vitest run --coverage",
		"unit:watch": "vitest watch",
		"test": "npm run lint && npm run types && npm run unit && npm run build"
	},
	"devDependencies": {
		"@prismicio/e2e-tests-utils": "1.15.0",
		"@prismicio/types-internal": "3.16.1",
		"@types/node": "25.0.9",
		"@vitest/coverage-v8": "4.0.17",
		"oxfmt": "^0.24.0",
		"oxlint": "1.39.0",
		"prismic-ts-codegen": "^0.1.28",
		"tsdown": "0.19.0",
		"typescript": "5.9.3",
		"valibot": "^1.2.0",
		"vitest": "4.0.17",
		"@sentry/node": "10.36.0",
		"chalk": "5.6.2",
		"listr2": "10.0.0",
		"open": "11.0.0",
		"semver": "7.7.3",
		"@types/semver": "7.7.1",
		"zod": "4.3.6"
	},
	"engines": {
		"node": ">=24"
	}
}
