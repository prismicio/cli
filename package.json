{
	"name": "prismic",
	"version": "0.0.0",
	"description": "Prismic's official command line tool",
	"keywords": [
		"prismic",
		"typescript"
	],
	"license": "Apache-2.0",
	"author": "Prismic <contact@prismic.io> (https://prismic.io)",
	"repository": {
		"type": "git",
		"url": "ssh://git@github.com/prismicio/cli.git"
	},
	"bin": {
		"prismic": "./dist/index.mjs"
	},
	"files": [
		"./dist",
		"./src"
	],
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format": "oxfmt",
		"prepare": "npm run build",
		"lint": "oxlint --deny-warnings --ignore-pattern packages/",
		"types": "tsc --noEmit",
		"unit": "vitest run --coverage",
		"unit:watch": "vitest watch",
		"test": "npm run lint && npm run types && npm run unit && npm run build"
	},
	"devDependencies": {
		"@amplitude/experiment-node-server": "1.13.2",
		"@antfu/ni": "28.2.0",
		"@prismicio/client": "7.21.3",
		"@prismicio/custom-types-client": "2.1.0",
		"@prismicio/e2e-tests-utils": "1.15.0",
		"@prismicio/types-internal": "3.16.1",
		"@segment/analytics-node": "2.3.0",
		"@sentry/node": "10.36.0",
		"@types/common-tags": "1.8.4",
		"@types/cors": "2.8.19",
		"@types/fs-extra": "11.0.4",
		"@types/node": "25.0.9",
		"@types/semver": "7.7.1",
		"@vitest/coverage-v8": "4.0.17",
		"chalk": "5.6.2",
		"change-case": "5.4.4",
		"common-tags": "1.8.2",
		"cookie": "1.1.1",
		"cors": "2.8.6",
		"dedent": "^1.7.2",
		"defu": "6.1.4",
		"detect-indent": "^7.0.2",
		"fp-ts": "2.16.11",
		"fs-extra": "11.3.3",
		"get-port": "7.1.0",
		"h3": "1.15.5",
		"io-ts": "2.2.22",
		"io-ts-types": "0.5.19",
		"listr2": "10.0.0",
		"magicast": "0.5.1",
		"node-fetch": "3.3.2",
		"open": "11.0.0",
		"oxfmt": "^0.24.0",
		"oxlint": "1.39.0",
		"p-limit": "7.2.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.4.1",
		"prismic-ts-codegen": "^0.1.28",
		"rc9": "2.1.2",
		"recast": "0.23.11",
		"semver": "7.7.3",
		"tinyglobby": "^0.2.15",
		"tsdown": "0.19.0",
		"typescript": "5.9.3",
		"valibot": "^1.2.0",
		"vitest": "4.0.17",
		"zod": "4.3.6"
	},
	"engines": {
		"node": ">=24"
	}
}
