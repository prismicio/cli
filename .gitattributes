# asserts everything is text
* text eol=lf

# treats lock files as binaries to prevent merge headache
package-lock.json -diff
yarn.lock -diff

# eval results are an append-only artifact; keep both sides on merge, skip diffs
evals/results.jsonl merge=union -diff

# treats assets as binaries
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
